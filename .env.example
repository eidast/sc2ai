# OpenCode Zen/Go LLM API configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit API keys.

# Required: Your OpenCode Go/Zen API key
# Create one at https://opencode.ai/auth
SC2AI_LLM_API_KEY=sk-opencode-xxxxxxxx

# Model to use for strategy analysis
# Available models via OpenCode Zen (chat/completions endpoint):
#   deepseek-v4-pro        $1.74/$3.48  (default, strong reasoning)
#   deepseek-v4-flash      $0.14/$0.28  (fast, cheap)
#   deepseek-v4-flash-free FREE          (limited time)
#   minimax-m2.7           $0.30/$1.20  (best cost/quality ratio)
#   qwen3.7-plus           $0.40/$1.60  (good balance)
#   qwen3.7-max            $2.50/$7.50  (most powerful open-weight)
#   kimi-k2.6              $0.95/$4.00  (strong reasoning)
#   gemini-3.1-pro         $2.00/$12.00 (Google)
#   claude-sonnet-4.6      $3.00/$15.00 (best reasoning, expensive)
SC2AI_LLM_MODEL=opencode-go/deepseek-v4-pro

# API endpoint for chat completions
SC2AI_LLM_BASE_URL=https://opencode.ai/zen/v1

# Maximum tokens in the response
SC2AI_LLM_MAX_TOKENS=32768

# Reasoning effort: none, minimal, low, medium, high, xhigh
SC2AI_LLM_REASONING_EFFORT=max

# Sampling temperature (0.0-2.0)
SC2AI_LLM_TEMPERATURE=0.7
